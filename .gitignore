# ============================================================================
# AXIOM .gitignore
# Repo root: E:/bin/axiom/  (all paths below are relative to this file)
# ============================================================================

# ----------------------------------------------------------------------------
# Excluded by request
# ----------------------------------------------------------------------------
# Student's Electron graph visualizer (separate project, has its own .gitignore)
/viewer/

# Generated export artifacts (regenerated by Stage 04 and view_graph.py)
/Python/export/
/Python/export_public/

# Website publish launcher, kept local by request
/run_publish_website.bat

# ----------------------------------------------------------------------------
# Databases
# ----------------------------------------------------------------------------
# Corpus index: 462 MB, exceeds GitHub's 100 MB per-file limit, and is fully
# rebuildable from the markdown corpus via Stages 02-03. Never commit.
/Python/lib/data/axiom.db

# SQLite sidecar files either DB may leave behind
/Python/lib/data/*.db-wal
/Python/lib/data/*.db-shm
/Python/lib/data/*.db-journal

# Curated knowledge graph: 3.3 MB and NOT rebuildable, but the raw file holds
# unredacted DrugBank narrative prose and conversation metadata. Keep it out of
# a public repo; the compliance path is the redacted export, not this file.
# Delete the next line only if this repo is private AND you want graph history
# tracked in git.
/Python/lib/data/axiom_graph.db

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
/Python/venv/
venv/
.venv/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ----------------------------------------------------------------------------
# R (carried over from the previous .gitignore)
# ----------------------------------------------------------------------------
.Rproj.user
.Rhistory
.RData
.Ruserdata

# ----------------------------------------------------------------------------
# Node / Electron (viewer is excluded wholesale above; defensive)
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-error.log*

# ----------------------------------------------------------------------------
# Secrets / credentials (none present today; guard the future)
# ----------------------------------------------------------------------------
.env
.env.*
*.key
*.pem
secrets.*
*_secret*
credentials.json

# ----------------------------------------------------------------------------
# OS / editor / IDE
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*~

# ----------------------------------------------------------------------------
# Temp / logs
# ----------------------------------------------------------------------------
*.tmp
*.md.tmp
*.log
